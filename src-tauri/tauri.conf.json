{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Copilot Rewrite",
  "version": "0.12.0",
  "identifier": "com.copilot-rewrite.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "splashscreen",
        "title": "Copilot Rewrite",
        "width": 320,
        "height": 280,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": true,
        "center": true,
        "focus": true,
        "shadow": false,
        "url": "splashscreen.html"
      },
      {
        "label": "popup",
        "title": "Copilot Rewrite",
        "width": 48,
        "height": 48,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false,
        "url": "index.html#/popup"
      },
      {
        "label": "settings",
        "title": "Copilot Rewrite Settings",
        "width": 480,
        "height": 640,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": false,
        "skipTaskbar": false,
        "center": true,
        "url": "index.html#/settings"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://github.com https://avatars.githubusercontent.com; connect-src 'self' https://api.github.com https://api.githubcopilot.com https://copilot-proxy.githubusercontent.com https://github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCRTdERDAyNUY5NkMyMzcKUldRM3dwWmZBdDNuYTVPOEhPVm93NUdaSGt2dEwrMlRhQVhMRDlCQnh6QVJXbzV1VWkvMDBVT3YK",
      "endpoints": [
        "https://github.com/wangmingliang-ms/copilot-rewrite/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
